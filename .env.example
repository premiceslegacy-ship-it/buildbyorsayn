# Supabase — Clés publiques (safe côté client)
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxx"

# Supabase — Service Role Key (PRIVÉE, serveur uniquement)
# Récupère-la dans : Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxxx"

# Stripe
# Récupère-la dans : Stripe Dashboard → Développeurs → Clés API
STRIPE_SECRET_KEY="sk_live_xxxx"
# Récupère-la dans : Stripe Dashboard → Développeurs → Webhooks → ton endpoint
STRIPE_WEBHOOK_SECRET="whsec_xxxx"

# Lien communauté privée (PRIVÉ, serveur uniquement — sans NEXT_PUBLIC_)
COMMUNITY_LINK="https://t.me/+..."
