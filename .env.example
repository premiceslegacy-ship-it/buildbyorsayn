# Supabase — Clés publiques (safe côté client)
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxx"

# Supabase — Service Role Key (PRIVÉE, serveur uniquement)
# Récupère-la dans : Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxxx"

# Lemon Squeezy
# Récupère-la dans : Lemon Squeezy → Settings → API
LEMON_SQUEEZY_API_KEY="eyJ0eXAiOiJKV1Qi..."
# Définis toi-même un secret fort lors de la création du webhook dans Lemon Squeezy
LEMON_SQUEEZY_WEBHOOK_SECRET="ton_secret_webhook_fort"
